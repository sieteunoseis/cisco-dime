{
  "name": "cisco-dime",
  "version": "2.0.1",
  "description": "A library to pull files from Cisco UC applications (VOS) via DIME",
  "main": "main.js",
  "module": "main.mjs",
  "types": "types/index.d.ts",
  "bin": {
    "cisco-dime": "./bin/cisco-dime.js"
  },
  "exports": {
    ".": {
      "import": "./main.mjs",
      "require": "./main.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=test node ./test/tests.js",
    "test:unit": "node ./test/unit.js",
    "development": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 NODE_TLS_REJECT_UNAUTHORIZED=0 NODE_ENV=development node ./test/tests.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sieteunoseis/cisco-dime.git"
  },
  "keywords": [
    "cisco",
    "node",
    "dime",
    "multipart",
    "cucm",
    "vos"
  ],
  "author": "Jeremy Worden <jeremy.worden@gmail.com> (https://github.com/sieteunoseis)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sieteunoseis/cisco-dime/issues"
  },
  "homepage": "https://github.com/sieteunoseis/cisco-dime#readme",
  "devDependencies": {
    "bluebird": "^3.5.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "fs-extra": "^7.0.1"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "csv-stringify": "^6.7.0",
    "debug": "^4.4.3",
    "xml2js": "^0.6.2"
  }
}
